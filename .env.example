# Root .env.example — 複製為 .env 並調整本機值

# PostgreSQL (matches docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=coach_cms
POSTGRES_USER=coach
POSTGRES_PASSWORD=coach_dev_password

# MinIO (S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=coach_admin
MINIO_SECRET_KEY=coach_dev_password
MINIO_BUCKET_VIDEOS=coach-videos
MINIO_BUCKET_THUMBNAILS=coach-thumbnails
MINIO_PUBLIC_URL=http://localhost:9000

# CMS API
CMS_API_PORT=8080
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRATION_MS=86400000

# CMS Web
NEXT_PUBLIC_API_URL=http://localhost:8080
CMS_WEB_PORT=3100
